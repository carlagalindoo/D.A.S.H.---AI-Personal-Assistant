<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - D.A.S.H</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/D.A.S.H.styles.css" asp-append-version="true" />
    <link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
        <div class="app-layout">

            <aside class="sidebar">
                <div class="sidebar-logo">
                    D.A.S.H
                </div>

            <nav class="sidebar-nav">

                <a class="sidebar-link @(Context.Request.Path == "/" ? "active" : "")"
                   asp-page="/Index">
                    🏠 Home
                </a>

                <a class="sidebar-link @(Context.Request.Path == "/ChatInterface" ? "active" : "")"
                   asp-page="/ChatInterface">
                    💬 Chat
                </a>

                <a class="sidebar-link @(Context.Request.Path.StartsWithSegments("/Tasks") ? "active" : "")"
                   asp-page="/Tasks/Index">
                    📋 Tasks
                </a>

                <a class="sidebar-link @(Context.Request.Path == "/Privacy" ? "active" : "")"
                   asp-page="/Privacy">
                    🔒 Privacy
                </a>

            </nav>
            </aside>

            <main class="main-content">
                @RenderBody()
            </main>

        </div>

        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>

        @await RenderSectionAsync("Scripts", required: false)
</body>
</html>