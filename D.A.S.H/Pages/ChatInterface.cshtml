@page
@model D.A.S.H.Pages.ChatInterfaceModel
@{
    
} 
<style>
    nav.navbar {
        margin-bottom: 20px !important;
    }

    main {
        padding-bottom: 0 !important;
    }

    footer {
        display: none;
    }

    .chat-page {
        height: calc(100vh - 120px);
        display: flex;
        justify-content: flex-end;
        margin-right: -30px;
    }

    .chat-card {
        width: 67vw;
        height: 100%;
    }

    .card-body {
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        min-height: 0;
    }

    form {
        margin-top: auto;
    }
</style>

<div class="chat-page">
    <div class="card rounded-0 chat-card">
        <div class="card-body d-flex flex-column">
            <h5 class="card-title">New Chat</h5>

            <div class="border rounded p-3 mb-3 flex-grow-1 chat-messages">

                @foreach (var message in Model.ChatMessages)
                {
                    <div class="mb-2 @(message.Sender == "AI" ? "text-primary" : "")">
                        <strong>@message.Sender:</strong> @message.Text
                    </div>
                }

            </div>

            <form method="post">
                <div class="input-group">
                    <input asp-for="UserRequest" class="form-control" placeholder="Type your request" />
                    <button type="submit" class="btn btn-primary">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>
