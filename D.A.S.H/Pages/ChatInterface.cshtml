@page
@model D.A.S.H.Pages.ChatInterfaceModel
@{
    
} 
<style>
    nav.navbar {
        margin-bottom: 20px !important;
    }

    main {
        padding-bottom: 0 !important;
    }

    footer {
        display: none;
    }

    .chat-page {
        height: calc(100vh - 73px - 60px); /* výška minus navbar a footer*/
        display: flex;
        justify-content: flex-end;
        margin-right: -30px;    }

    .chat-card {
        width: 67vw;
        height: 100%;
    }
</style>

<div class="chat-page">
    <div class="card rounded-0 chat-card">
        <div class="card-body d-flex flex-column">
            <h5 class="card-title">New Chat</h5>

            <div class="border rounded p-3 mb-3 flex-grow-1" style="min-height: 0;">
            </div>

            <form>
                <div class="input-group">
                    <input type="text" class="form-control" placeholder="Type your request">
                    <button type="submit" class="btn btn-primary">Submit</button>
                </div>
            </form>
        </div>
    </div>
</div>
