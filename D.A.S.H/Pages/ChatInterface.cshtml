@page
@model D.A.S.H.Pages.ChatInterfaceModel
@{
    
} 
<style>
    nav.navbar {
        margin-bottom: 20px !important;
    }

    main {
        padding-bottom: 0 !important;
    }

    footer {
        display: none;
    }

    .chat-page {
        height: calc(100vh - 120px);
        display: flex;
        justify-content: center;
        padding: 40px 40px;
    }

    .chat-card {
        width: 100%;
        max-width: 1200px;
        height: 85vh;
        box-shadow: 0 4px 20px rgba(45, 52, 54, 0.08);
        border: none;
    }

    .card-body {
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        min-height: 0;
    }

    .message-row {
        display: flex;
        margin-bottom: 12px;
    }

    .user-row {
        justify-content: flex-end;
    }

    .ai-row {
        justify-content: flex-start;
    }

    .message-bubble {
        max-width: 70%;
        padding: 12px 16px;
        border-radius: 18px;
        font-size: 15px;
        line-height: 1.4;
        word-wrap: break-word;
    }

    .ai-bubble {
        background-color: #F5F6FA; /* Secondary */
        color: #2D3436; /* Text */
        border-bottom-left-radius: 4px;
        border: 1px solid #B2BEC3; /* Muted */
    }

    .user-bubble {
        background-color: #A29BFE; /* Accent */
        color: white;
        border-bottom-right-radius: 4px;
    }

    .ai-avatar {
        margin-right: 12px;
        font-size: 34px;
        font-weight: bold;
        color: #A29BFE; /* Accent */
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .send-btn {
        background: transparent;
        border: none;
        color: #A29BFE; /* Accent */
        font-size: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 15px;
    }

        .send-btn:hover {
            color: #8f87f5; /* Slightly darker accent */
            background: transparent;
        }

        .send-btn:focus {
            box-shadow: none;
        }

    .user-avatar {
        margin-left: 12px;
        font-size: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: transparent;
        border: none;
        border-radius: 0;
        width: auto;
        height: auto;
        flex-shrink: 0;
    }

    form {
        margin-top: auto;
    }
</style>

<div class="chat-page">
    <div class="card rounded-0 chat-card">
        <div class="card-body d-flex flex-column">
            <h5 class="card-title">💬 D.A.S.H Assistant</h5>

            <div class="chat-messages border rounded p-3 mb-3">

                @foreach (var message in Model.ChatMessages)
                {
                    var isUser = message.Sender == "You";

                    <div class="message-row @(isUser ? "user-row" : "ai-row")">
                        @if (!isUser)
                        {
                            <div class="ai-avatar">D</div>
                        }
                        <div class="message-bubble @(isUser ? "user-bubble" : "ai-bubble")">
                            @message.Text
                        </div>

                        @if (isUser)
                        {
                            <div class="user-avatar">👤</div>
                        }
                    </div>
                }

            </div>

            <form method="post">
                <div class="input-group">
                    <input asp-for="UserRequest" class="form-control" placeholder="Type your request" />
                    <button type="submit" class="send-btn">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
