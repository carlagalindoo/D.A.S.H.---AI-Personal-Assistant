@page
@model D.A.S.H.Pages.Tasks.IndexModel

@{
    ViewData["Title"] = "Tasks";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Tasks</h2>
        <a asp-page="/Tasks/Create" class="btn btn-add-task">
            Add Task
        </a>
    </div>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Description</th>
                <th>Date</th>
                <th>Time</th>
                <th>Location</th>
                <th>People</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Tasks.Any())
            {
                @foreach (var task in Model.Tasks)
                {
                    <tr>
                        <td>@task.TaskId</td>
                        <td>@task.Title</td>
                        <td>@task.Description</td>
                        <td>@task.Date.ToString("dd/MM/yyyy")</td>
                        <td>@DateTime.Today.Add(task.Time).ToString("h:mm tt", System.Globalization.CultureInfo.InvariantCulture)</td>
                        <td>@task.Location</td>
                        <td>@task.People</td>
                        <td>
                            <a asp-page="/Tasks/Edit" asp-route-id="@task.TaskId" class="btn btn-sm btn-edit-task">Edit</a>
                            <a asp-page="/Tasks/Delete" asp-route-id="@task.TaskId" class="btn btn-sm btn-delete-task">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center">No tasks found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>