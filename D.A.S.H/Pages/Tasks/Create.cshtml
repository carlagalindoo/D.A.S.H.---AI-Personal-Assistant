@page
@model D.A.S.H.Pages.Tasks.CreateModel

@{
    ViewData["Title"] = "Create Task";
}

<div class="container mt-4">
    <h2 class="mb-3">Create Task</h2>

    <form method="post">
        <div class="mb-3">
            <label asp-for="TaskItem.SessionKey" class="form-label"></label>
            <input asp-for="TaskItem.SessionKey" class="form-control" />
            <span asp-validation-for="TaskItem.SessionKey" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="TaskItem.Title" class="form-label"></label>
            <input asp-for="TaskItem.Title" class="form-control" />
            <span asp-validation-for="TaskItem.Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="TaskItem.Description" class="form-label"></label>
            <textarea asp-for="TaskItem.Description" class="form-control"></textarea>
            <span asp-validation-for="TaskItem.Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="TaskItem.Date" class="form-label"></label>
            <input asp-for="TaskItem.Date" type="date" class="form-control" />
            <span asp-validation-for="TaskItem.Date" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="TaskItem.Time" class="form-label"></label>
            <input asp-for="TaskItem.Time" type="time" asp-format="{0:HH:mm}" class="form-control" />
            <span asp-validation-for="TaskItem.Time" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="TaskItem.Location" class="form-label"></label>
            <input asp-for="TaskItem.Location" class="form-control" />
            <span asp-validation-for="TaskItem.Location" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="TaskItem.People" class="form-label"></label>
            <input asp-for="TaskItem.People" class="form-control" />
            <span asp-validation-for="TaskItem.People" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Save</button>
        <a asp-page="/Tasks/Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
